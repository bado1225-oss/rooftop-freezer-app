// =====================================================================
// rooftop-freezer-app Firestore セキュリティルール
//
// 方針:
//   - 認証済みユーザーは「自分のデータ」だけ読み書きできる
//   - 他人のデータには絶対アクセスできない
//   - 未認証は全拒否
//
// 使い方:
//   Firebase Console → Firestore Database → 「ルール」タブ
//   → このファイルの中身をそのままコピーして貼り付け → 公開
// =====================================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザー自身のドキュメント
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 商品データ
      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 操作履歴
      match /history/{historyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // それ以外はすべて拒否（重要）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
